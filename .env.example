# ===========================================
# Eavesight Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# App Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stormvault?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (for auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# Map Services (choose one)
# Option 1: MapLibre with OpenStreetMap (free)
NEXT_PUBLIC_MAP_PROVIDER=maplibre
NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Option 2: Mapbox (requires API key)
# NEXT_PUBLIC_MAP_PROVIDER=mapbox
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# External APIs
# NOAA (free)
NOAA_API_KEY=
NOAA_API_URL=https://www.ncei.noaa.gov/access/services/data/v1

# Property Data Providers (choose one or multiple)
ESTATED_API_KEY=
ESTATED_API_URL=https://api.estated.com/v4

SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=
SMARTY_API_URL=https://www.smarty.com/api/us-property

BUILDFAX_API_KEY=
BUILDFAX_API_URL=https://api.buildfax.com

# Contact Data
DATAZAPP_API_KEY=
DATAZAPP_API_URL=https://api.datazapp.com

# File Storage (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=eavesight-files
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Email (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eavesight.com

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_STORM_SYNC=true
ENABLE_AI_FEATURES=false
