# Dependencies
node_modules/
.pnpm-store/

# Build outputs
.next/
out/
dist/
build/

# Environment files — NEVER commit any .env*, regardless of suffix.
# Only .env.example (documented placeholders) is allowed in git.
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Misc
*.tgz
*.tar.gz
node_modules
*.tsbuildinfo

# Large data / pipeline outputs — kept locally on VM, never committed
data/
output/
*.pmtiles
*.mbtiles
*.ndjson
*.grib2
*.geojsonl

# Keep small demo pmtiles used by the frontend
!apps/frontend/public/buildings-huntsville.pmtiles
!apps/frontend/public/buildings-v3.pmtiles
