# Dependencies
node_modules/
.pnpm-store/

# Build outputs
.next/
out/
dist/
build/

# Environment files — NEVER commit any .env*, regardless of suffix.
# Only .env.example (documented placeholders) is allowed in git.
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs — entire logs/ tree, plus catch-all log extensions/suffixes
logs/
*.log
*.log.*
*.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Alternate package managers — this repo uses npm (package-lock.json).
# pnpm-lock.yaml shows up if someone runs `pnpm install`; ignore so the
# two lockfiles can't drift.
pnpm-lock.yaml

# Testing
coverage/
.nyc_output/

# Misc
*.tgz
*.tar.gz
node_modules
*.tsbuildinfo

# Large data / pipeline outputs — kept locally on VM, never committed
data/
output/
*.pmtiles
*.mbtiles
*.ndjson
*.grib2
*.geojsonl

# Keep small demo pmtiles used by the frontend
!apps/frontend/public/buildings-huntsville.pmtiles
!apps/frontend/public/buildings-v3.pmtiles
