+// ---------------------------------------------------------------------------
+// Scale-ready: Metros, H3 aggregates, Pin-card denorm
+// ---------------------------------------------------------------------------
+model Metro {
+  code          String    @id
+  name          String
+  stateCodes    String[]
+  counties      String[]  @default([])
+  centerLat     Float
+  centerLon     Float
+  bboxMinLat    Float
+  bboxMaxLat    Float
+  bboxMinLon    Float
+  bboxMaxLon    Float
+  defaultZoom   Int       @default(9)
+  tier          String    @default("free")
+  status        String    @default("active")
+  launchedAt    DateTime?
+  createdAt     DateTime  @default(now())
+  updatedAt     DateTime  @updatedAt
+
+  hexAggregates PropertyHexAggregate[]
+  pinCards      PropertyPinCard[]
+
+  @@index([status])
+  @@map("metros")
+}
+
+model PropertyHexAggregate {
+  id            String   @id @default(cuid())
+  metroCode     String
+  resolution    Int
+  h3Cell        String
+  n             Int      @default(0)
+  scoreP50      Float?
+  scoreP90      Float?
+  scoreMax      Float?
+  dormantCount  Int      @default(0)
+  hailMaxInches Float?
+  avgRoofAge    Float?
+  centerLat     Float
+  centerLon     Float
+  updatedAt     DateTime @default(now()) @updatedAt
+
+  metro Metro @relation(fields: [metroCode], references: [code], onDelete: Cascade)
+
+  @@unique([metroCode, resolution, h3Cell])
+  @@index([metroCode, resolution])
+  @@map("property_hex_aggregates")
+}
+
+model PropertyPinCard {
+  propertyId     String   @id
+  metroCode      String?
+  payloadFree    Json
+  payloadPro     Json
+  score          Float?
+  dormantFlag    Boolean  @default(false)
+  // Canonical roof-age source bucket used to build the payload.
+  // Top-level column so filters/sorts don't need JSONB extracts.
+  // Values: measured | coc | permit | inferred | unknown.
+  roofAgeSource  String?
+  updatedAt      DateTime @default(now()) @updatedAt
+
+  metro Metro? @relation(fields: [metroCode], references: [code], onDelete: SetNull)
+
+  @@index([metroCode])
+  @@index([metroCode, score(sort: Desc)])
+  @@index([metroCode], map: "pin_cards_dormant_idx")
+  @@index([metroCode, roofAgeSource])
+  @@map("property_pin_cards")
+}
