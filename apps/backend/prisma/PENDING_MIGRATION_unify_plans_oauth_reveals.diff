+// One row per first-time reveal of a property's PII per org per billing period.
+// Subsequent reveals of the same property by the same org in the same period are NOT billable.
+// `kind` lets us track reveal types separately ("reveal" = owner contact, "roof" = roof measurement).
+model PropertyReveal {
+  id          String       @id @default(uuid())
+  orgId       String
+  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
+  propertyId  String
+  userId      String
+  user        User         @relation(fields: [userId], references: [id])
+  kind        RevealKind   @default(REVEAL)
+  periodStart DateTime
+  revealedAt  DateTime     @default(now())
+  costCents   Int          @default(0)
+
+  @@unique([orgId, propertyId, kind, periodStart])
+  @@index([orgId, periodStart])
+  @@index([orgId, kind, periodStart])
+  @@map("property_reveals")
+}
+
+enum RevealKind {
+  REVEAL
+  ROOF_MEASUREMENT
+}
