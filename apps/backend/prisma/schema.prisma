// StormVault Prisma Schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  firstName      String?
  lastName       String?
  role           UserRole  @default(USER)
  emailVerified  DateTime?
  avatar         String?
  phone          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organizationMemberships OrganizationMember[]
  leads                   Lead[]              @relation("Assignee")
  sessions                Session[]
  activities              Activity[]
  canvassSessions         CanvassSession[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      Plan    @default(STARTER)
  logo      String?
  website   String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  stripeCustomerId String?
  trialEndsAt      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrganizationMember[]
  leads       Lead[]
  apiKeys     ApiKey[]
  territories Territory[]
  campaigns   Campaign[]
  apiUsage    ApiUsage[]
  apiQuotas   ApiQuota[]

  @@map("organizations")
}

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrgMemberRole   @default(MEMBER)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model ApiKey {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  key       String   @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Property {
  id          String   @id @default(cuid())

  address     String
  address2    String?
  city        String
  state       String   @db.VarChar(2)
  zip         String   @db.VarChar(10)
  county      String?
  fips        String?  @db.VarChar(5)

  lat         Float?
  lon         Float?

  propertyType   PropertyType @default(RESIDENTIAL)
  yearBuilt      Int?
  sqft           Int?
  lotSizeSqft    Int?
  stories        Int?
  bedrooms       Int?
  bathrooms      Float?

  assessedValue     Float?
  marketValue       Float?
  lastSalePrice     Float?
  lastSaleDate      DateTime?
  taxAmount         Float?

  ownerFirstName    String?
  ownerLastName     String?
  ownerFullName     String?
  ownerMailAddress  String?
  ownerMailCity     String?
  ownerMailState    String?
  ownerMailZip      String?
  ownerOccupied     Boolean?

  ownerPhone        String?
  ownerPhone2       String?
  ownerEmail        String?
  ownerEmail2       String?
  phoneVerified     Boolean  @default(false)
  emailVerified     Boolean  @default(false)
  onDncList         Boolean  @default(false)

  parcelId       String?
  parcelNumber   String?
  legalDesc      String?
  zoning         String?

  attomId        String?
  rentcastId     String?

  source         String?
  sourceUpdatedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propertyStorms    PropertyStorm[]
  leads             Lead[]
  roofData          RoofData?
  buildingFootprint BuildingFootprint?
  enrichments       PropertyEnrichment?
  activities        Activity[]

  @@unique([address, city, state, zip])
  @@index([lat, lon])
  @@index([state, city])
  @@index([state, county])
  @@index([parcelId])
  @@index([zip])
  @@index([ownerLastName, ownerFirstName])
  @@map("properties")
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MULTI_FAMILY
  INDUSTRIAL
  VACANT_LAND
  OTHER
}

model RoofData {
  id              String   @id @default(cuid())
  propertyId      String   @unique

  totalAreaSqft   Float?
  pitchDegrees    Float?
  pitchRatio      String?
  facets          Int?

  segments        Json?

  material        RoofMaterial?
  age             Int?
  condition       RoofCondition?
  color           String?

  ridgeLength     Float?
  hipLength       Float?
  valleyLength    Float?
  eaveLength      Float?
  rakeLength      Float?
  flashingLength  Float?

  estimatedSquares     Float?
  estimatedWasteFactor Float?
  estimatedMaterialCost Float?
  estimatedLaborCost    Float?
  estimatedTotalCost    Float?

  source          String?
  confidence      Float?
  measuredAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("roof_data")
}

enum RoofMaterial {
  ASPHALT_SHINGLE
  METAL
  TILE_CLAY
  TILE_CONCRETE
  SLATE
  WOOD_SHAKE
  FLAT_MEMBRANE
  TPO
  EPDM
  BUILT_UP
  UNKNOWN
}

enum RoofCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
  UNKNOWN
}

model BuildingFootprint {
  id            String   @id @default(cuid())
  propertyId    String   @unique

  geometry      Json
  areaSqft      Float?
  centroidLat   Float?
  centroidLon   Float?

  source        String
  sourceId      String?

  createdAt     DateTime @default(now())

  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([centroidLat, centroidLon])
  @@map("building_footprints")
}

model StormEvent {
  id          String   @id @default(cuid())

  type        StormType
  severity    Severity?
  date        DateTime
  endDate     DateTime?

  city        String?
  county      String?
  state       String  @db.VarChar(2)
  lat         Float?
  lon         Float?
  endLat      Float?
  endLon      Float?

  hailSizeInches   Float?
  windSpeedMph     Float?
  tornadoFScale    String?

  pathGeometry     Json?
  affectedArea     Json?
  widthYards       Float?
  lengthMiles      Float?

  damageEstimate   Float?
  deathsDirect     Int?
  injuriesDirect   Int?
  propertiesDamaged Int?

  description String?
  source      String?
  sourceId    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  propertyStorms PropertyStorm[]

  @@index([date])
  @@index([state, date])
  @@index([type, severity])
  @@index([lat, lon])
  @@map("storm_events")
}

enum StormType {
  HAIL
  TORNADO
  WIND
  HURRICANE
  FLOOD
  TSTM
  OTHER
}

enum Severity {
  LIGHT
  MODERATE
  SEVERE
  EXTREME
}

model PropertyStorm {
  id           String   @id @default(cuid())
  propertyId   String
  stormEventId String
  distanceMeters Float?
  affected     Boolean  @default(false)
  damageLevel  DamageLevel?
  claimFiled   Boolean?
  permitPulled Boolean?
  createdAt    DateTime @default(now())

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  stormEvent StormEvent @relation(fields: [stormEventId], references: [id], onDelete: Cascade)

  @@unique([propertyId, stormEventId])
  @@map("property_storms")
}

enum DamageLevel {
  NONE
  MINOR
  MODERATE
  MAJOR
  DESTROYED
}

model Lead {
  id             String      @id @default(cuid())
  orgId          String
  propertyId     String?
  parcelId       String?  // Madison County PIN for parcel-based leads

  firstName      String?
  lastName       String?
  email          String?
  phone          String?

  status         LeadStatus  @default(NEW)
  source         String?
  score          Int         @default(50)
  priority       Priority    @default(MEDIUM)

  assigneeId     String?
  assignedAt     DateTime?

  quotedAmount   Float?
  contractAmount Float?
  insuranceClaim Boolean?
  insuranceCarrier String?
  deductible     Float?

  notes          String?
  tags           String[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  contactedAt     DateTime?
  appointmentAt   DateTime?
  inspectedAt     DateTime?
  quotedAt        DateTime?
  convertedAt     DateTime?
  lostAt          DateTime?
  lostReason      String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignee     User?       @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  activities   Activity[]

  @@index([orgId, status])
  @@index([orgId, score])
  @@index([assigneeId])
  @@index([createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT
  INSPECTED
  QUALIFIED
  QUOTED
  NEGOTIATING
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Activity {
  id         String       @id @default(cuid())
  leadId     String?
  propertyId String?
  userId     String?

  type       ActivityType
  title      String
  notes      String?
  metadata   Json?

  createdAt  DateTime     @default(now())

  lead       Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  SMS
  VISIT
  INSPECTION
  QUOTE
  STATUS_CHANGE
  SYSTEM
}

model CanvassSession {
  id          String   @id @default(cuid())
  userId      String

  startedAt   DateTime @default(now())
  endedAt     DateTime?

  route       Json?

  doorsKnocked  Int    @default(0)
  doorsAnswered  Int   @default(0)
  leadsGenerated Int   @default(0)

  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("canvass_sessions")
}

model Campaign {
  id          String        @id @default(cuid())
  orgId       String
  name        String
  type        CampaignType
  status      CampaignStatus @default(DRAFT)

  targetZips     String[]
  targetStormIds String[]
  targetMinScore Int?

  subject     String?
  body        String?
  template    String?

  sentCount      Int   @default(0)
  deliveredCount Int   @default(0)
  openedCount    Int   @default(0)
  clickedCount   Int   @default(0)
  repliedCount   Int   @default(0)

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("campaigns")
}

enum CampaignType {
  EMAIL
  SMS
  DIRECT_MAIL
  DOOR_KNOCK
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
}

model PropertyEnrichment {
  id                    String   @id @default(cuid())
  propertyId            String   @unique

  censusTract           String?
  censusBlockGroup      String?
  medianHouseholdIncome Float?
  medianHomeValue       Float?
  homeownershipRate     Float?
  medianAge             Float?
  populationDensity     Float?

  femaRiskScore         Float?
  floodZone             String?
  disasterDeclarationActive Boolean? @default(false)
  lastDisasterDate      DateTime?
  lastDisasterType      String?

  avgRoofCostPerSqft    Float?
  avgLaborRatePerHour   Float?
  materialCostIndex     Float?

  stormDamageScore      Float?
  leadQualityScore      Float?
  roofReplacementLikelihood Float?

  estimatedRoofSqft     Int?
  estimatedJobValue     Int?
  solarRoofData         Json?

  ownerName             String?
  ownerPhone            String?
  ownerEmail            String?
  ownerMailingAddress   String?
  skipTraceData         Json?

  source                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_enrichments")
}

model DncEntry {
  id          String   @id @default(cuid())
  phone       String   @unique
  source      String
  addedAt     DateTime @default(now())

  @@index([phone])
  @@map("dnc_entries")
}

model DataIngestionJob {
  id         String             @id @default(cuid())
  type       String
  status     IngestionStatus    @default(PENDING)

  state      String?
  county     String?
  zipCode    String?

  totalRecords    Int    @default(0)
  processedRecords Int   @default(0)
  errorCount      Int    @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("data_ingestion_jobs")
}

enum IngestionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Territory {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  zipCodes  String[]
  geometry  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("territories")
}

model ApiUsage {
  id          String   @id @default(uuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])
  service     String
  endpoint    String
  credits     Int      @default(1)
  costCents   Int      @default(0)
  metadata    Json?
  propertyId  String?
  leadId      String?
  createdAt   DateTime @default(now())

  @@index([orgId, service])
  @@index([orgId, createdAt])
  @@index([service, createdAt])
  @@map("api_usage")
}

model ApiQuota {
  id            String   @id @default(uuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id])
  service       String
  monthlyLimit  Int
  usedThisMonth Int      @default(0)
  resetAt       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([orgId, service])
  @@map("api_quotas")
}

// Raw Madison County parcel data from City of Huntsville ArcGIS
// Source: https://maps.huntsvilleal.gov/server/rest/services/Planning/FindAProperty/MapServer
model MadisonParcelData {
  id String @id @default(cuid())

  pin                    String   @unique // Parcel ID (primary key)
  objectId               Int?     // ArcGIS OBJECTID

  propertyAddress        String?
  totalBuildingValue     Float?
  totalAppraisedValue    Float?
  acres                  Float?
  zoning                 String?
  eDistrictName          String?
  wetland                String?
  floodZone              String?
  highSchool             String?
  hubZone                String?
  industrialPark         String?
  localHistoricDistrict  String?
  nationalHistoricDistrict String?
  historicBuilding       String?
  opportunityZone        String?
  tifDistrict            String?
  slopeDistrict          String?
  trafficCount           Int?
  majorRoad              String?

  // Proximity flags (within 15/30 min drive)
  bridgeStreet15         String?
  hospital15             String?
  marshall15             String?
  nhip15                 String?
  toyota15               String?
  bridgeStreet30         String?
  hospital30             String?
  marshall30             String?
  nhip30                 String?
  toyota30               String?

  // Owner info (from KCSGIS layer 185)
  propertyOwner          String?
  accountOwner           String?
  mailingAddress         String?
  mailingAddressFull     String?
  previousOwners         String?
  taxDistrict            String?
  totalLandValue         Float?
  totalAssessedValue     Float?
  subdivision           String?
  neighborhoodName       String?
  deedType               String?
  deedBook               String?
  deedPage               String?
  deedDate               DateTime?

  // Harvest tracking
  lastHarvestedAt       DateTime @default(now())
  lastOwnerEnrichedAt   DateTime?

  // Geocoded coordinates
  lat                    Float?
  lon                    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pin])
  @@index([lastHarvestedAt])
  @@index([propertyAddress])
  @@index([totalAppraisedValue])
  @@index([lat, lon])
  @@map("madison_parcel_data")
}
